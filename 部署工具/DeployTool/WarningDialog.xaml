<Window x:Class="DeployTool.WarningDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="危险操作警告"
        Height="Auto" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Background="#FFF5F5"
        AllowsTransparency="True"
        WindowStyle="None"
        BorderBrush="#C53030"
        BorderThickness="2"
        ManipulationBoundaryFeedback="Window_ManipulationBoundaryFeedback">
    <Border CornerRadius="8" Background="#FFF5F5">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <Border Width="48" Height="48" Background="#FED7D7" CornerRadius="24" Margin="0,0,16,0">
                    <TextBlock Text="⚠" FontSize="24" FontWeight="Bold" Foreground="#C53030" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="危险操作警告" FontSize="18" FontWeight="Bold" Foreground="#C53030"/>
                    <TextBlock Text="此操作不可撤销，请谨慎确认！" FontSize="11" Foreground="#9B2C2C" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,20"
                    BorderBrush="#FC8181" BorderThickness="1">
                <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="13" Foreground="#742A2A"
                               LineHeight="22"/>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="90" Height="34" Margin="0,0,12,0" Click="CancelButton_Click"
                        FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E2E8F0"/>
                            <Setter Property="Foreground" Value="#4A5568"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#CBD5E0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="ConfirmButton" Content="确认执行" Width="100" Height="34" Click="OkButton_Click" IsDefault="True"
                        FontSize="13" FontWeight="Medium" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#C53030"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#9B2C2C"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
