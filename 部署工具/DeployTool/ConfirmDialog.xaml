<Window x:Class="DeployTool.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认执行"
        Height="Auto" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Background="#F0F4F8"
        AllowsTransparency="True"
        WindowStyle="None"
        BorderBrush="#3182CE"
        BorderThickness="1">
    <Border CornerRadius="8" Background="#F0F4F8">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <Border Width="48" Height="48" Background="#EBF8FF" CornerRadius="24" Margin="0,0,16,0">
                    <TextBlock Text="!" FontSize="28" FontWeight="Bold" Foreground="#3182CE" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="确认执行" FontSize="18" FontWeight="Bold" Foreground="#1E3A5F"/>
                    <TextBlock Text="请仔细阅读以下操作内容" FontSize="11" Foreground="#718096" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,20"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="13" Foreground="#2D3748"
                               LineHeight="22"/>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="90" Height="34" Margin="0,0,12,0" Click="CancelButton_Click"
                        FontSize="13" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E2E8F0"/>
                            <Setter Property="Foreground" Value="#4A5568"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#CBD5E0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="确定执行" Width="100" Height="34" Click="OkButton_Click" IsDefault="True"
                        FontSize="13" FontWeight="Medium" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#3182CE"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#2B6CB0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
