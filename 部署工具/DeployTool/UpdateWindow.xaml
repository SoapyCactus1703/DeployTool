<Window x:Class="DeployTool.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="检查更新" Height="500" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F4F8"
        AllowsTransparency="True"
        WindowStyle="None"
        BorderBrush="#3182CE"
        BorderThickness="2">
    <Border CornerRadius="8" Background="#F0F4F8">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <Border Width="48" Height="48" Background="#EBF8FF" CornerRadius="24" Margin="0,0,16,0">
                    <TextBlock Text="⬆" FontSize="24" FontWeight="Bold" Foreground="#3182CE" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="软件更新" FontSize="20" FontWeight="Bold" Foreground="#1E3A5F"/>
                    <TextBlock x:Name="CurrentVersionText" Text="当前版本: v12.1.0" FontSize="11" Foreground="#718096" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="1">
                <!-- 检查中 -->
                <StackPanel x:Name="CheckingPanel" Visibility="Visible" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Height="6" Margin="0,0,0,16"/>
                    <TextBlock Text="正在检查更新..." HorizontalAlignment="Center" 
                               FontSize="14" Foreground="#718096"/>
                </StackPanel>

                <!-- 无更新 -->
                <StackPanel x:Name="NoUpdatePanel" Visibility="Collapsed" VerticalAlignment="Center">
                    <Border Width="72" Height="72" Background="#E8F5E9" CornerRadius="36" Margin="0,0,0,16"
                            HorizontalAlignment="Center">
                        <TextBlock Text="✓" FontSize="36" FontWeight="Bold" Foreground="#38A169" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="您使用的是最新版本！" FontSize="16" FontWeight="Medium" 
                               HorizontalAlignment="Center" Foreground="#2D3748"/>
                    <TextBlock x:Name="NoUpdateVersionText" Text="" 
                               HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="#718096" FontSize="12"/>
                </StackPanel>

                <!-- 发现新版本 / 当前版本信息 -->
                <StackPanel x:Name="UpdateAvailablePanel" Visibility="Collapsed">
                    <Border x:Name="VersionBorder" Background="#E8F5E9" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                            BorderBrush="#38A169" BorderThickness="2">
                        <StackPanel>
                            <TextBlock x:Name="NewVersionText" Text="发现新版本: v0.0.0" 
                                       FontSize="16" FontWeight="Bold" Foreground="#276749"/>
                            <TextBlock x:Name="ReleaseDateText" Text="发布日期: " 
                                       Margin="0,6,0,0" Foreground="#718096" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="更新内容" FontWeight="SemiBold" FontSize="13" Foreground="#2D3748" Margin="0,0,0,8"/>
                    <Border Background="White" CornerRadius="6" Padding="12" MaxHeight="160"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="ReleaseNotesText" TextWrapping="Wrap" FontSize="12" Foreground="#4A5568"
                                       LineHeight="20"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <!-- 下载中 -->
                <StackPanel x:Name="DownloadingPanel" Visibility="Collapsed" VerticalAlignment="Center">
                    <TextBlock x:Name="DownloadStatusText" Text="正在下载更新..." 
                               HorizontalAlignment="Center" FontSize="14" Foreground="#2D3748" Margin="0,0,0,20"/>
                    <ProgressBar x:Name="DownloadProgressBar" Height="8" Minimum="0" Maximum="100"
                                 Foreground="#3182CE"/>
                    <TextBlock x:Name="DownloadProgressText" Text="0%" 
                               HorizontalAlignment="Center" Margin="0,12,0,0" Foreground="#3182CE" FontWeight="Medium"/>
                    <TextBlock x:Name="DownloadSpeedText" Text="" 
                               HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="#718096" FontSize="11"/>
                </StackPanel>

                <!-- 错误 -->
                <StackPanel x:Name="ErrorPanel" Visibility="Collapsed" VerticalAlignment="Center">
                    <Border Width="72" Height="72" Background="#FED7D7" CornerRadius="36" Margin="0,0,0,16"
                            HorizontalAlignment="Center">
                        <TextBlock Text="✕" FontSize="36" FontWeight="Bold" Foreground="#E53E3E" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="检查更新失败" FontSize="16" FontWeight="Medium" 
                               HorizontalAlignment="Center" Foreground="#2D3748"/>
                    <TextBlock x:Name="ErrorText" Text="" FontSize="12" 
                               HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="#718096" 
                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="350"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="DownloadButton" Content="立即下载" Width="100" Height="34" 
                        Visibility="Collapsed" Click="DownloadButton_Click" Margin="0,0,12,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#38A169"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#276749"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="InstallButton" Content="安装更新" Width="100" Height="34" 
                        Visibility="Collapsed" Click="InstallButton_Click" Margin="0,0,12,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#38A169"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#276749"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="OpenReleaseButton" Content="查看发布页" Width="100" Height="34" 
                        Visibility="Collapsed" Click="OpenReleaseButton_Click" Margin="0,0,12,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E2E8F0"/>
                            <Setter Property="Foreground" Value="#4A5568"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#CBD5E0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="CancelButton" Content="取消" Width="80" Height="34" 
                        Visibility="Collapsed" Click="CancelButton_Click" Margin="0,0,12,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E2E8F0"/>
                            <Setter Property="Foreground" Value="#4A5568"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#CBD5E0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="CloseButton" Content="关闭" Width="80" Height="34" Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#3182CE"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#2B6CB0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
