<Window x:Class="DeployTool.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="检查更新" Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45a049"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                  Fill="#4CAF50" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"
                  VerticalAlignment="Center"/>
            <TextBlock Text="软件更新" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
        
        <Grid Grid.Row="1" x:Name="ContentGrid">
            <StackPanel x:Name="CheckingPanel" Visibility="Visible">
                <TextBlock Text="正在检查更新..." HorizontalAlignment="Center" VerticalAlignment="Center" 
                           FontSize="16" Foreground="#666666"/>
                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,15,0,0"/>
            </StackPanel>
            
            <StackPanel x:Name="NoUpdatePanel" Visibility="Collapsed">
                <TextBlock Text="✓" FontSize="48" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                <TextBlock Text="您使用的是最新版本！" FontSize="16" HorizontalAlignment="Center" 
                           Margin="0,15,0,0" Foreground="#333333"/>
                <TextBlock x:Name="CurrentVersionText" Text="当前版本: v9.5.0" 
                           HorizontalAlignment="Center" Margin="0,10,0,0" Foreground="#666666"/>
            </StackPanel>
            
            <StackPanel x:Name="UpdateAvailablePanel" Visibility="Collapsed">
                <Border Background="#E8F5E9" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock x:Name="NewVersionText" Text="发现新版本: v9.6.0" 
                                   FontSize="18" FontWeight="Bold" Foreground="#2E7D32"/>
                        <TextBlock x:Name="ReleaseDateText" Text="发布日期: 2024-01-15" 
                                   Margin="0,5,0,0" Foreground="#666666"/>
                    </StackPanel>
                </Border>
                
                <TextBlock Text="更新内容:" FontWeight="Bold" Margin="0,0,0,8"/>
                <Border Background="#FFFFFF" CornerRadius="4" Padding="10" MaxHeight="150">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ReleaseNotesText" TextWrapping="Wrap" Foreground="#333333"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>
            
            <StackPanel x:Name="DownloadingPanel" Visibility="Collapsed">
                <TextBlock x:Name="DownloadStatusText" Text="正在下载更新..." 
                           HorizontalAlignment="Center" FontSize="16" Margin="0,0,0,15"/>
                <ProgressBar x:Name="DownloadProgressBar" Height="8" Minimum="0" Maximum="100"/>
                <TextBlock x:Name="DownloadProgressText" Text="0%" 
                           HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="#666666"/>
                <TextBlock x:Name="DownloadSpeedText" Text="" 
                           HorizontalAlignment="Center" Margin="0,5,0,0" Foreground="#999999" FontSize="12"/>
            </StackPanel>
            
            <StackPanel x:Name="ErrorPanel" Visibility="Collapsed">
                <TextBlock Text="✕" FontSize="48" Foreground="#F44336" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorText" Text="检查更新失败" FontSize="16" 
                           HorizontalAlignment="Center" Margin="0,15,0,0" Foreground="#333333" 
                           TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
        </Grid>
        
        <StackPanel Grid.Row="2" x:Name="ButtonPanel" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="DownloadButton" Content="立即下载" Style="{StaticResource PrimaryButton}" 
                    Visibility="Collapsed" Click="DownloadButton_Click"/>
            <Button x:Name="InstallButton" Content="安装更新" Style="{StaticResource PrimaryButton}" 
                    Visibility="Collapsed" Click="InstallButton_Click"/>
            <Button x:Name="OpenReleaseButton" Content="查看发布页" Style="{StaticResource SecondaryButton}" 
                    Visibility="Collapsed" Click="OpenReleaseButton_Click" Margin="10,0,0,0"/>
            <Button x:Name="CancelButton" Content="取消" Style="{StaticResource SecondaryButton}" 
                    Visibility="Collapsed" Click="CancelButton_Click"/>
            <Button x:Name="CloseButton" Content="关闭" Style="{StaticResource SecondaryButton}" 
                    Click="CloseButton_Click"/>
        </StackPanel>
        
        <TextBlock Grid.Row="3" x:Name="GitHubHintText" 
                   Text="提示: 请在AppSettings中配置GitHub仓库地址" 
                   Foreground="#FF9800" FontSize="12" Margin="0,10,0,0"
                   Visibility="Collapsed"/>
    </Grid>
</Window>
