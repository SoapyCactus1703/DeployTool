<Window x:Class="DeployTool.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Height="620" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F4F8">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="系统设置" FontSize="18" FontWeight="Bold" Foreground="#1E3A5F" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="监控设置" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,12"/>
                        
                        <CheckBox x:Name="EnableCpuTempCheckBox" Content="启用系统数据监控" 
                                  FontSize="13" Margin="0,0,0,12" IsChecked="True"/>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="刷新间隔:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox Grid.Column="1" x:Name="RefreshIntervalTextBox" Text="1" VerticalContentAlignment="Center" Padding="8,6"/>
                            <TextBlock Grid.Column="2" Text="秒" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="时间同步设置" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,12"/>
                        
                        <CheckBox x:Name="AutoSyncTimeCheckBox" Content="自动同步系统时间" 
                                  FontSize="13" Margin="0,0,0,12" IsChecked="True"/>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NTP 服务器:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox Grid.Column="1" x:Name="NtpServerTextBox" Text="210.72.145.44" VerticalContentAlignment="Center" Padding="8,6"/>
                        </Grid>
                        
                        <TextBlock Text="常用 NTP 服务器：" FontSize="11" Foreground="#718096" Margin="0,8,0,4"/>
                        <ComboBox x:Name="NtpServerComboBox" Margin="0,0,0,8">
                            <ComboBoxItem Content="国家授时中心 (210.72.145.44)" Tag="210.72.145.44"/>
                            <ComboBoxItem Content="阿里云 NTP (ntp.aliyun.com)" Tag="ntp.aliyun.com"/>
                            <ComboBoxItem Content="腾讯云 NTP (ntp.tencent.com)" Tag="ntp.tencent.com"/>
                            <ComboBoxItem Content="Windows 时间 (time.windows.com)" Tag="time.windows.com"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="任务执行标记" FontWeight="SemiBold" Foreground="#4A5568" HorizontalAlignment="Left"/>
                            <Button Content="清除全部" Click="ClearAllFlags_Click" HorizontalAlignment="Right" 
                                    FontSize="11" Padding="8,4">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="#E53E3E" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="White"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#C53030"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                        
                        <TextBlock Text="以下显示已执行的任务标记：" FontSize="11" Foreground="#718096" Margin="0,0,0,8"/>
                        
                        <ItemsControl x:Name="FlagsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F7FAFC" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,8,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#48BB78"/>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            
                                            <TextBlock Grid.Column="1" Text="{Binding Description}" VerticalAlignment="Center" FontSize="12"/>
                                            
                                            <Button Grid.Column="2" Content="清除" Tag="{Binding Key}" Click="ClearFlag_Click"
                                                    FontSize="10" Padding="6,2">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border" Background="#E2E8F0" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Background" Value="#CBD5E0"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <TextBlock x:Name="NoFlagsText" Text="暂无执行标记" FontSize="12" Foreground="#A0AEC0" 
                                   HorizontalAlignment="Center" Margin="0,16,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="预设配置" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,12"/>
                        
                        <TextBlock Text="选择预设配置可快速设置常用选项：" FontSize="11" Foreground="#718096" Margin="0,0,0,8"/>
                        
                        <Button Content="教学环境预设" Click="TeachingPreset_Click" Margin="0,0,0,8"
                                HorizontalContentAlignment="Left" Padding="12,8">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#F7FAFC" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                            BorderBrush="#E2E8F0" BorderThickness="1">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#EDF2F7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Content="办公环境预设" Click="OfficePreset_Click" Margin="0,0,0,8"
                                HorizontalContentAlignment="Left" Padding="12,8">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#F7FAFC" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                            BorderBrush="#E2E8F0" BorderThickness="1">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#EDF2F7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button Content="恢复默认设置" Click="DefaultPreset_Click"
                                HorizontalContentAlignment="Left" Padding="12,8">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#F7FAFC" CornerRadius="4" Padding="{TemplateBinding Padding}"
                                            BorderBrush="#E2E8F0" BorderThickness="1">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#EDF2F7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Background="#FFF5F5" CornerRadius="6" Padding="16"
                        BorderBrush="#FC8181" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="部署完成清理" FontWeight="SemiBold" Foreground="#C53030" Margin="0,0,0,8"/>
                        
                        <TextBlock Text="完成所有部署任务后，可使用此功能清理部署工具。" FontSize="11" Foreground="#718096" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <TextBlock Text="警告：此操作将强制关闭程序并删除程序所在目录及所有文件！" FontSize="11" Foreground="#C53030" Margin="0,0,0,12" TextWrapping="Wrap"/>
                        
                        <Button Content="清理部署工具" Click="SelfDestruct_Click" Foreground="White" HorizontalAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#C53030" CornerRadius="4" Padding="12,8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#9B2C2C"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Width="80" Height="28" Margin="0,0,8,0" Click="Cancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#E2E8F0" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CBD5E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="保存" Width="80" Height="28" Click="Save_Click" Foreground="White">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#3182CE" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2B6CB0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
