<Window x:Class="DeployTool.WindowsEasySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows轻松设置"
        Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F4F8">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D4A6F" Padding="20,15">
            <Grid>
                <TextBlock Text="Windows轻松设置" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock x:Name="LoadingText" Text="正在检测系统状态..." FontSize="12" Foreground="#A0C4E8" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="15,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="6" Margin="0,0,10,0">
                <ListBox x:Name="CategoryListBox" SelectionChanged="CategoryListBox_SelectionChanged"
                         BorderThickness="0" Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="border" Background="Transparent" Padding="15,12" Margin="5,2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#E8F4FD"/>
                                                <Setter TargetName="border" Property="BorderBrush" Value="#3182CE"/>
                                                <Setter TargetName="border" Property="BorderThickness" Value="3,0,0,0"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F7FAFC"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem Content="系统核心设置" Tag="System" IsSelected="True"/>
                    <ListBoxItem Content="安全与防护设置" Tag="Security"/>
                    <ListBoxItem Content="资源管理器增强" Tag="Explorer"/>
                    <ListBoxItem Content="性能与服务优化" Tag="Performance"/>
                </ListBox>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="6">
                <Grid>
                    <ScrollViewer x:Name="SettingsScrollViewer" VerticalScrollBarVisibility="Auto" Padding="15">
                        <StackPanel>
                            <StackPanel x:Name="SystemPanel" Visibility="Visible">
                                <TextBlock Text="系统核心设置" FontSize="14" FontWeight="SemiBold" Foreground="#2D3748" Margin="0,0,0,15"/>
                                <StackPanel x:Name="SystemSettingsPanel"/>
                            </StackPanel>

                            <StackPanel x:Name="SecurityPanel" Visibility="Collapsed">
                                <TextBlock Text="安全与防护设置" FontSize="14" FontWeight="SemiBold" Foreground="#2D3748" Margin="0,0,0,15"/>
                                <StackPanel x:Name="SecuritySettingsPanel"/>
                            </StackPanel>

                            <StackPanel x:Name="ExplorerPanel" Visibility="Collapsed">
                                <TextBlock Text="资源管理器增强" FontSize="14" FontWeight="SemiBold" Foreground="#2D3748" Margin="0,0,0,15"/>
                                <StackPanel x:Name="ExplorerSettingsPanel"/>
                            </StackPanel>

                            <StackPanel x:Name="PerformancePanel" Visibility="Collapsed">
                                <TextBlock Text="性能与服务优化" FontSize="14" FontWeight="SemiBold" Foreground="#2D3748" Margin="0,0,0,15"/>
                                <StackPanel x:Name="PerformanceSettingsPanel"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#F7FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="15,10">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="就绪" FontSize="12" Foreground="#718096"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="刷新状态" Width="90" Height="32" Margin="0,0,10,0" Click="Refresh_Click"
                            Background="#E2E8F0" Foreground="#4A5568" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#CBD5E0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="关闭" Width="80" Height="32" Click="Close_Click"
                            Background="#3182CE" Foreground="White" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#2B6CB0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
